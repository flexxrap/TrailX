# Telegram Bot
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=trailxapp_bot
PORT=3001
WEBHOOK_DOMAIN=

# GraphHopper (server-side only — never expose to frontend)
GRAPHHOPPER_API_KEY=your_graphhopper_key_here

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session auth secret
AUTH_SECRET=your_auth_secret_here

# Payment providers
CRYPTOPAY_TOKEN=
CRYPTOPAY_TESTNET=true   # remove in production

# TON direct — monitors wallet for incoming transactions (polling every 30s)
# Testnet wallet: Tonkeeper → Settings → tap logo 5x → Dev Menu → Switch to Testnet
# Testnet coins: @testgiver_ton_bot
# API key: @toncenter bot → Create API Key (separate keys for testnet/mainnet!)
TON_WALLET_ADDRESS=
TONCENTER_API_KEY=
TONCENTER_TESTNET=true   # remove in production

# WebPay.by
WEBPAY_RESOURCE_ID=
WEBPAY_API_KEY=
WEBPAY_SECRET_KEY=
WEBPAY_SANDBOX=true
WEBPAY_NOTIFY_URL=